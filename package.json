{
  "name": "pi-supergsd",
  "version": "0.1.0",
  "description": "Curated, patched Superpowers skills packaged for Pi",
  "type": "module",
  "scripts": {
    "updater": "tsx updater/updater.ts",
    "lint": "eslint '**/*.ts'",
    "fix": "eslint '**/*.ts' --fix",
    "test": "tsx --test '**/*.test.ts'",
    "verify": "npm run lint && npx tsc --noEmit && npm test && npm run updater && git diff --exit-code -- skills && npm pack --dry-run"
  },
  "keywords": [
    "pi-package",
    "pi",
    "skills",
    "superpowers"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skhoroshavin/pi-supergsd.git"
  },
  "homepage": "https://github.com/skhoroshavin/pi-supergsd#readme",
  "bugs": {
    "url": "https://github.com/skhoroshavin/pi-supergsd/issues"
  },
  "license": "MIT",
  "files": [
    "index.ts",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "skills": [
      "./skills"
    ],
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "eslint-plugin-unslop": "^0.7.3",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  }
}
