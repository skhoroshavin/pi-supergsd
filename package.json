{
  "name": "pi-supergsd",
  "version": "0.2.8",
  "description": "Curated, patched Superpowers skills packaged for Pi",
  "type": "module",
  "scripts": {
    "updater": "tsx updater/updater.ts",
    "fix": "prettier --write '**/*.ts' && eslint '**/*.ts' --fix",
    "test": "tsx --test '**/*.test.ts'",
    "verify": "npx tsc --noEmit && eslint '**/*.ts' && npm test && npm run updater && prettier --check '**/*.ts'"
  },
  "keywords": [
    "pi-package",
    "pi",
    "skills",
    "superpowers"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skhoroshavin/pi-supergsd.git"
  },
  "homepage": "https://github.com/skhoroshavin/pi-supergsd#readme",
  "bugs": {
    "url": "https://github.com/skhoroshavin/pi-supergsd/issues"
  },
  "license": "MIT",
  "files": [
    "index.ts",
    "src/index.ts",
    "src/text-content.ts",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "skills": [
      "./skills"
    ],
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.75.5",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "eslint-plugin-unslop": "^0.7.3",
    "prettier": "^3.8.3",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  }
}
